# Phase 0 is a static SPA and does not read this value at runtime.
# Reserve this database name for future backend or offline ingestion work.
APP_DATABASE_NAME=AI意匠ver2_DB
DB_PROJECT_PATH=../特許ダウンロード手順_0
JPO_BULK_WORKAREA=<local-db-workarea-outside-app-repository>
LOCAL_JPO_JSON_EXAMPLE=<select-db-generated-json-with-file-api>

# Do not put database credentials in VITE_* variables.
# Vite exposes VITE_* values to the browser bundle.
